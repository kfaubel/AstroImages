{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "ApexAstro: Run Release",
      "type": "coreclr",
      "request": "launch",
      "noDebug": true,
      "preLaunchTask": "build ApexAstro Release",
      "program": "${workspaceFolder}/ApexAstro.Wpf/bin/Release/net8.0-windows/ApexAstro.exe",
      "cwd": "${workspaceFolder}/ApexAstro.Wpf",
      "console": "internalConsole",
      "stopAtEntry": false
    }
  ]
}
