{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build ApexAstro Debug",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/ApexAstro.Wpf/ApexAstro.Wpf.csproj",
        "-c",
        "Debug"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build ApexAstro Release",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/ApexAstro.Wpf/ApexAstro.Wpf.csproj",
        "-c",
        "Release"
      ],
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
