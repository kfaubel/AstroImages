{
  "name": "astro-images",
  "version": "1.0.0",
  "description": "Astronomical Image Viewer - A specialized two-pane image viewer for astronomical images, particularly FITS files.",
  "main": "main.js",
  "homepage": "https://github.com/kfaubel/AstroImages",
  "repository": {
    "type": "git",
    "url": "https://github.com/kfaubel/AstroImages.git"
  },
  "bugs": {
    "url": "https://github.com/kfaubel/AstroImages/issues"
  },
  "keywords": [
    "astronomy",
    "fits",
    "image-viewer",
    "electron",
    "astrophotography",
    "fits-files",
    "astronomical-images"
  ],
  "scripts": {
    "start": "electron-forge start",
    "dev": "electron . --dev",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "make:win": "electron-forge make --platform=win32",
    "make:mac": "electron-forge make --platform=darwin",
    "make:linux": "electron-forge make --platform=linux",
    "build": "electron-builder",
    "lint": "echo \"No linting configured\"",
    "test": "echo \"No tests configured\""
  },
  "author": "Ken Faubel",
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.10.2",
    "@electron-forge/maker-deb": "^7.10.2",
    "@electron-forge/maker-rpm": "^7.10.2",
    "@electron-forge/maker-squirrel": "^7.10.2",
    "@electron-forge/maker-zip": "^7.10.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.10.2",
    "@electron-forge/plugin-fuses": "^7.10.2",
    "@electron-forge/publisher-github": "^7.10.2",
    "@electron/fuses": "^1.8.0",
    "electron": "^27.0.0"
  },
  "dependencies": {
    "canvas": "^3.2.0",
    "electron-squirrel-startup": "^1.0.1",
    "smart-buffer": "^4.2.0"
  },
  "build": {
    "appId": "com.astro-images.app",
    "productName": "Astro Images",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "src/**/*",
      "preload.js",
      "index.html",
      "styles.css",
      "fits-worker.js",
      "icon.ico",
      "splash.png",
      "node_modules/**/*"
    ],
    "win": {
      "target": "dir",
      "icon": "icon.ico",
      "sign": false
    }
  }
}
