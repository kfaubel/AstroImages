<Window x:Class="ApexAstro.Wpf.GraphWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="Graph" Height="820" Width="1200"
        MinHeight="400" MinWidth="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ThemeWindowBackground}"
        Foreground="{DynamicResource ThemeForeground}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0"
                Background="{DynamicResource ThemeToolbarBackground}"
                BorderBrush="{DynamicResource ThemeBorderBrush}"
                BorderThickness="0,0,0,1" Padding="6,4">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="ModifyButton" Content="Modify Graph…"
                Click="ModifyButton_Click" Padding="10,4"/>
            </StackPanel>
        </Border>

        <!-- OxyPlot chart + hover overlay -->
        <Grid Grid.Row="1">
            <oxy:PlotView x:Name="PlotView"
                          Background="{DynamicResource ThemeWindowBackground}"/>

            <!-- Canvas overlay for hover tooltip (IsHitTestVisible=False so mouse passes through) -->
            <Canvas x:Name="HoverCanvas" IsHitTestVisible="False">
                <Border x:Name="HoverBorder" Visibility="Collapsed"
                        Background="{DynamicResource ThemeWindowBackground}"
                        BorderBrush="{DynamicResource ThemeBorderBrush}"
                        BorderThickness="1" CornerRadius="4"
                        Padding="8,6" MinWidth="160" MaxWidth="300">
                    <ScrollViewer MaxHeight="320"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="HoverContent"/>
                    </ScrollViewer>
                </Border>
            </Canvas>
        </Grid>
    </Grid>
</Window>
