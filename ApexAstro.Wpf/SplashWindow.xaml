<Window x:Class="ApexAstro.Wpf.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ApexAstro" Height="760" Width="760"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        Icon="icon.ico"
        ResizeMode="CanResize"
        MinHeight="540" MinWidth="560">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Compact Header: image left, title/info right -->
        <Grid Grid.Row="0" Background="#003351">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0" Source="splash.png" Height="110" Width="110"
                   Stretch="Uniform" Margin="16,12,8,12" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,12,16,12">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="ApexAstro" FontSize="26" FontWeight="Bold"
                               Foreground="White" FontFamily="Segoe UI Light" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="Astronomical Image Viewer" FontSize="14"
                           Foreground="#E3F2FD" Margin="0,4,0,0" FontFamily="Segoe UI"/>
                <TextBlock x:Name="VersionTextBlock" Text="Version" FontSize="12"
                           Foreground="#BBDEFB" Margin="0,4,0,0" FontFamily="Segoe UI"/>
                <TextBlock FontSize="11" Foreground="#90A4AE" Margin="0,4,0,0" FontFamily="Segoe UI">
                    <Run Text="Copyright © "/>
                    <Run x:Name="CopyrightYear"/>
                    <Run Text=" Ken Faubel. All rights reserved."/>
                </TextBlock>
            </StackPanel>
        </Grid>

        <!-- Embedded help content -->
        <TabControl Grid.Row="1" Name="SplashTabControl"
                    Background="{DynamicResource ThemeWindowBackground}"
                    Foreground="{DynamicResource ThemeForeground}">
            <TabItem Header="Getting Started">
                <FlowDocumentScrollViewer Name="SplashGettingStartedViewer" Margin="4"
                                          Background="{DynamicResource ThemeWindowBackground}"
                                          Foreground="{DynamicResource ThemeForeground}">
                    <FlowDocument Name="SplashGettingStartedContent" FontFamily="Segoe UI" FontSize="15"
                                  PagePadding="16,12"
                                  Background="{DynamicResource ThemeWindowBackground}"
                                  Foreground="{DynamicResource ThemeForeground}"/>
                </FlowDocumentScrollViewer>
            </TabItem>
            <TabItem Header="Documentation">
                <FlowDocumentScrollViewer Name="SplashDocumentationViewer" Margin="4"
                                          Background="{DynamicResource ThemeWindowBackground}"
                                          Foreground="{DynamicResource ThemeForeground}">
                    <FlowDocument Name="SplashDocumentationContent" FontFamily="Segoe UI" FontSize="15"
                                  PagePadding="16,12"
                                  Background="{DynamicResource ThemeWindowBackground}"
                                  Foreground="{DynamicResource ThemeForeground}"/>
                </FlowDocumentScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Footer: utility buttons left, checkbox + OK right -->
        <Border Grid.Row="2" Background="#003351" Padding="12,10">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Button Name="CheckUpdatesButton" Content="Check for Updates" Width="130" Height="28"
                            Click="CheckUpdatesButton_Click" Foreground="White" BorderThickness="0"
                            FontFamily="Segoe UI" FontSize="12" Cursor="Hand" Margin="0,0,6,0"
                            Background="#2E7D32">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#2E7D32"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="8,4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#388E3C"/></Trigger>
                                                <Trigger Property="IsPressed"   Value="True"><Setter Property="Background" Value="#1B5E20"/></Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Name="ViewLogButton" Content="View Log" Width="80" Height="28"
                            Click="ViewLogButton_Click" Foreground="White" BorderThickness="0"
                            FontFamily="Segoe UI" FontSize="12" Cursor="Hand" Margin="0,0,6,0"
                            Background="#455A64">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#455A64"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="8,4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#546E7A"/></Trigger>
                                                <Trigger Property="IsPressed"   Value="True"><Setter Property="Background" Value="#37474F"/></Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Name="FeedbackButton" Content="Feedback" Width="80" Height="28"
                            Click="FeedbackButton_Click" Foreground="White" BorderThickness="0"
                            FontFamily="Segoe UI" FontSize="12" Cursor="Hand"
                            Background="#455A64">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#455A64"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="8,4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#546E7A"/></Trigger>
                                                <Trigger Property="IsPressed"   Value="True"><Setter Property="Background" Value="#37474F"/></Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <CheckBox Name="DontShowAgainCheckBox" Content="Skip showing this at startup"
                              VerticalAlignment="Center" Margin="0,0,20,0"
                              Foreground="White" FontFamily="Segoe UI" FontSize="12"/>
                    <Button Name="OkButton" Content="OK" Width="80" Height="32"
                            Click="OkButton_Click" IsDefault="True"
                            Foreground="White" BorderThickness="0"
                            FontFamily="Segoe UI" FontSize="13" FontWeight="Medium" Cursor="Hand"
                            Background="#3f51b5">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#3f51b5"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="8,4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#5c6bc0"/></Trigger>
                                                <Trigger Property="IsPressed"   Value="True"><Setter Property="Background" Value="#303f9f"/></Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
