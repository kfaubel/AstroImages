<Window x:Class="ApexAstro.Wpf.DocumentationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ApexAstro Help" Height="600" Width="800"
        MinWidth="600" MinHeight="400" 
        Icon="icon.ico"
        Background="{DynamicResource ThemeWindowBackground}"
        Foreground="{DynamicResource ThemeForeground}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Help Content Tabs -->
        <TabControl Name="HelpTabControl" Grid.Row="0" Margin="10"
                    Background="{DynamicResource ThemeWindowBackground}"
                    Foreground="{DynamicResource ThemeForeground}">
            <TabItem Header="Getting Started">
                <FlowDocumentScrollViewer Name="GettingStartedViewer"
                                          Background="{DynamicResource ThemeWindowBackground}"
                                          Foreground="{DynamicResource ThemeForeground}">
                    <FlowDocument Name="GettingStartedContent" FontFamily="Segoe UI" FontSize="16"
                                  Background="{DynamicResource ThemeWindowBackground}"
                                  Foreground="{DynamicResource ThemeForeground}">
                        <!-- Content will be loaded dynamically -->
                    </FlowDocument>
                </FlowDocumentScrollViewer>
            </TabItem>
            <TabItem Header="Documentation">
                <FlowDocumentScrollViewer Name="DocumentViewer"
                                          Background="{DynamicResource ThemeWindowBackground}"
                                          Foreground="{DynamicResource ThemeForeground}">
                    <FlowDocument Name="DocumentContent" FontFamily="Segoe UI" FontSize="16"
                                  Background="{DynamicResource ThemeWindowBackground}"
                                  Foreground="{DynamicResource ThemeForeground}">
                        <!-- Content will be loaded dynamically -->
                    </FlowDocument>
                </FlowDocumentScrollViewer>
            </TabItem>
        </TabControl>
        
        <!-- Close Button -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Content="Close" Width="80" Height="30" Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>