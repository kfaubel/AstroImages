<UserControl x:Class="ApexAstro.Wpf.HistogramControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ApexAstro.Wpf"
             mc:Ignorable="d" 
             d:DesignHeight="200" d:DesignWidth="800"
             Background="{DynamicResource ThemeWindowBackground}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Histogram Header with Controls -->
        <Border Grid.Row="0" 
                Background="{DynamicResource ThemeSidebarBackground}" 
                BorderBrush="{DynamicResource ThemeBorderBrush}" 
                BorderThickness="0,1,0,1"
                Padding="8,4">
            <Grid>
                <TextBlock Text="Histogram" 
                           FontSize="12" 
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource ThemeForeground}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <RadioButton x:Name="LinearRadioButton" 
                                 Content="Linear" 
                                 IsChecked="{Binding IsLinearScale, Mode=TwoWay}"
                                 Margin="0,0,12,0"
                                 VerticalAlignment="Center"
                                 Foreground="{DynamicResource ThemeForeground}"/>
                    <RadioButton x:Name="LogarithmicRadioButton" 
                                 Content="Logarithmic" 
                                 IsChecked="{Binding IsLogarithmicScale, Mode=TwoWay}"
                                 VerticalAlignment="Center"
                                 Foreground="{DynamicResource ThemeForeground}"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Histogram Display Area -->
        <Border Grid.Row="1" 
                Background="{DynamicResource ThemeImageAreaBackground}" 
                BorderBrush="{DynamicResource ThemeBorderBrush}" 
                BorderThickness="0,0,0,1"
                Margin="4">
            <Grid>
                <!-- Placeholder text when no image -->
                <TextBlock x:Name="PlaceholderText"
                           Text="No histogram data available" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource ThemeSecondaryText}"
                           Visibility="{Binding HasHistogramData, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                
                <!-- Canvas for drawing histogram -->
                <Canvas x:Name="HistogramCanvas"
                        Background="Transparent"
                        Visibility="{Binding HasHistogramData, Converter={StaticResource BooleanToVisibilityConverter}}"
                        SizeChanged="HistogramCanvas_SizeChanged"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
