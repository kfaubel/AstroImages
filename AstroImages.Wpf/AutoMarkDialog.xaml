<Window x:Class="AstroImages.Wpf.AutoMarkDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Auto Select" 
        Height="600" 
        Width="700"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ThemeWindowBackground}"
        BorderBrush="{DynamicResource ThemeBorderBrush}"
        BorderThickness="1"
        Icon="icon.ico">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Message -->
        <TextBlock Grid.Row="0" 
                   Text="Files that do NOT meet the enabled criteria will be marked for deletion. Enable the check for each keyword and set the acceptable range or allowed values." 
                   FontSize="12"
                   Foreground="{DynamicResource ThemeForeground}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,15"/>

        <!-- Table -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header Row -->
            <Border Grid.Row="0" Background="{DynamicResource ThemeHeaderBackground}" Padding="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="" FontWeight="Bold" Foreground="{DynamicResource ThemeForeground}" Padding="4,6"/>
                    <TextBlock Grid.Column="1" Text="Keyword" FontWeight="Bold" Foreground="{DynamicResource ThemeForeground}" Padding="4,6"/>
                    <TextBlock Grid.Column="2" Text="Allow Blank" FontWeight="Bold" Foreground="{DynamicResource ThemeForeground}" Padding="4,6"/>
                    <TextBlock Grid.Column="3" Text="Min" FontWeight="Bold" Foreground="{DynamicResource ThemeForeground}" Padding="4,6"/>
                    <TextBlock Grid.Column="4" Text="Max" FontWeight="Bold" Foreground="{DynamicResource ThemeForeground}" Padding="4,6"/>
                    <TextBlock Grid.Column="5" Text="Allowed Values (comma-separated)" FontWeight="Bold" Foreground="{DynamicResource ThemeForeground}" Padding="4,6"/>
                </Grid>
            </Border>

            <!-- Keyword Rows in ScrollViewer -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" VerticalAlignment="Stretch">
                <ItemsControl x:Name="KeywordsItemsControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel Orientation="Vertical" IsVirtualizing="False"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2,0,2" Height="Auto">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Enable Check -->
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Center"
                                          ToolTip="Enable this criteria check"/>

                                <!-- Keyword Name -->
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Key}" 
                                           Foreground="{DynamicResource ThemeForeground}"
                                           Padding="4,6"
                                           VerticalAlignment="Center"/>

                                <!-- Allow Blank Checkbox -->
                                <CheckBox Grid.Column="2"
                                          IsChecked="{Binding AllowBlank, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          IsEnabled="{Binding IsEnabled}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Center"
                                          ToolTip="If unchecked, files with blank/missing values will be marked"/>

                                <!-- Min Value TextBox -->
                                <TextBox Grid.Column="3"
                                         Text="{Binding MinValue, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding IsEnabled}"
                                         Foreground="{DynamicResource ThemeForeground}"
                                         Background="{DynamicResource ThemeTextBoxBackground}"
                                         BorderBrush="{DynamicResource ThemeBorderBrush}"
                                         Padding="4,4"
                                         Margin="2"
                                         ToolTip="Minimum acceptable value (numeric)"/>

                                <!-- Max Value TextBox -->
                                <TextBox Grid.Column="4"
                                         Text="{Binding MaxValue, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding IsEnabled}"
                                         Foreground="{DynamicResource ThemeForeground}"
                                         Background="{DynamicResource ThemeTextBoxBackground}"
                                         BorderBrush="{DynamicResource ThemeBorderBrush}"
                                         Padding="4,4"
                                         Margin="2"
                                         ToolTip="Maximum acceptable value (numeric)"/>

                                <!-- Allowed Values TextBox -->
                                <TextBox Grid.Column="5"
                                         Text="{Binding AllowedValues, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding IsEnabled}"
                                         Foreground="{DynamicResource ThemeForeground}"
                                         Background="{DynamicResource ThemeTextBoxBackground}"
                                         BorderBrush="{DynamicResource ThemeBorderBrush}"
                                         Padding="4,4"
                                         Margin="2"
                                         ToolTip="Comma-separated list of allowed non-numeric values (e.g., Ha,OIII,SII)"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="Apply" 
                    Width="80" 
                    Margin="0,0,10,0"
                    Click="ApplyButton_Click"/>
            <Button Content="Cancel" 
                    Width="80" 
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
