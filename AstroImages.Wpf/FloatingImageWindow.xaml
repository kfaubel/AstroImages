<Window x:Class="AstroImages.Wpf.FloatingImageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Image Viewer" 
        Height="600" 
        Width="800"
        MinWidth="400" 
        MinHeight="300"
        Icon="icon.ico"
        Background="{DynamicResource ThemeWindowBackground}"
        BorderBrush="{DynamicResource ThemeBorderBrush}"
        BorderThickness="1"
        PreviewKeyDown="FloatingImageWindow_PreviewKeyDown">
    <Window.InputBindings>
        <KeyBinding Key="Left" Command="{Binding GotoPreviousCommand}" />
        <KeyBinding Key="Right" Command="{Binding GotoNextCommand}" />
        <KeyBinding Key="Home" Command="{Binding GotoFirstCommand}" />
        <KeyBinding Key="End" Command="{Binding GotoLastCommand}" />
        <KeyBinding Key="Add" Command="{Binding ZoomInCommand}" />
        <KeyBinding Key="Subtract" Command="{Binding ZoomOutCommand}" />
        <KeyBinding Key="OemPlus" Command="{Binding ZoomInCommand}" />
        <KeyBinding Key="OemMinus" Command="{Binding ZoomOutCommand}" />
    </Window.InputBindings>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Image View Controls -->
        <Grid Name="ImageControlsGrid" Grid.Row="0" Margin="8,8,8,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="-" Width="40" Margin="4" Command="{Binding ZoomOutCommand}" />
                <Button Content="+" Width="40" Margin="4" Command="{Binding ZoomInCommand}" />
                <Button Content="1:1" Width="50" Margin="4" Command="{Binding ZoomActualCommand}" />
                <Button Content="Fit" Width="50" Margin="4" Command="{Binding FitToWindowCommand}" />
                <TextBlock Text="{Binding ZoomDisplayText}" 
                           VerticalAlignment="Center" 
                           Margin="8"
                           Foreground="{DynamicResource ThemeForeground}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <!-- Auto Stretch Control -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0,8,0">
                    <TextBlock Text="Stretch:" 
                               VerticalAlignment="Center" 
                               Margin="0,0,4,0"
                               Foreground="{DynamicResource ThemeForeground}"/>
                    <Button Content="-" Width="24" Height="24" Margin="2" 
                            Command="{Binding DecreaseStretchCommand}"
                            ToolTip="Decrease stretch aggressiveness"/>
                    <TextBlock Text="{Binding StretchDisplayText}" 
                               VerticalAlignment="Center" 
                               HorizontalAlignment="Center"
                               Width="24"
                               TextAlignment="Center"
                               Margin="2"
                               Foreground="{DynamicResource ThemeForeground}"/>
                    <Button Content="+" Width="24" Height="24" Margin="2" 
                            Command="{Binding IncreaseStretchCommand}"
                            ToolTip="Increase stretch aggressiveness"/>
                </StackPanel>
                <Button Width="36" Height="32" Margin="4" 
                        Click="FullScreenButton_Click"
                        ToolTip="Enter full screen mode (F11)">
                    <Path Data="M5,5H10V7H7V10H5V5M14,5H19V10H17V7H14V5M17,14H19V19H14V17H17V14M10,17V19H5V14H7V17H10Z" 
                          Fill="{DynamicResource ThemeButtonForeground}" 
                          Stretch="Uniform" 
                          Width="18" Height="18"/>
                </Button>
                <Button Width="36" Height="32" Margin="4" 
                        Click="DockBackButton_Click"
                        ToolTip="Dock image and histogram back to main window">
                    <Path Data="M4,4H20A2,2 0 0,1 22,6V18A2,2 0 0,1 20,20H4A2,2 0 0,1 2,18V6A2,2 0 0,1 4,4M4,6V18H11V6H4M20,18V6H18V18H20M13,6V18H16V6H13Z" 
                          Fill="{DynamicResource ThemeButtonForeground}" 
                          Stretch="Uniform" 
                          Width="18" Height="18"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Image Display Area -->
        <Grid Grid.Row="1" Background="#333333">
            <TextBlock Name="PlaceholderText" Text="Select an image from the file list" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <ScrollViewer Name="ImageScrollViewer"
                         Visibility="Collapsed"
                         HorizontalScrollBarVisibility="{Binding ScrollBarVisibility}"
                         VerticalScrollBarVisibility="{Binding ScrollBarVisibility}"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Stretch"
                         Background="#333333"
                         PreviewMouseWheel="ImageScrollViewer_PreviewMouseWheel">
                <Image Name="DisplayImage"
                       Stretch="None"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Top"
                       RenderTransformOrigin="0,0"
                       MouseLeftButtonDown="DisplayImage_MouseLeftButtonDown"
                       MouseLeftButtonUp="DisplayImage_MouseLeftButtonUp"
                       MouseMove="DisplayImage_MouseMove"
                       RenderOptions.BitmapScalingMode="Fant">
                    <Image.RenderTransform>
                        <ScaleTransform ScaleX="{Binding ZoomLevel}" ScaleY="{Binding ZoomLevel}" />
                    </Image.RenderTransform>
                </Image>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
